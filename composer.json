{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6",
        "knplabs/knp-paginator-bundle": "^6.10",
        "stof/doctrine-extensions-bundle": "^1.15",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2.10",
        "symfony/form": "7.4.*",
        "symfony/framework-bundle": "7.4.*",
        "symfony/runtime": "7.4.*",
        "symfony/security-bundle": "7.4.*",
        "symfony/translation": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/yaml": "7.4.*",
        "twig/intl-extra": "^3.26"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.3",
        "escapestudios/symfony2-coding-standard": "*",
        "fakerphp/faker": "^1.24",
        "friendsofphp/php-cs-fixer": "^3.95.1",
        "rector/rector": "^2.4.2",
        "squizlabs/php_codesniffer": "*",
        "symfony/maker-bundle": "^1.67"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "static-analysis": [
            "./vendor/bin/phpcs --config-set installed_paths $(realpath vendor/escapestudios/symfony2-coding-standard)",
            "./vendor/bin/phpcs --config-set default_standard Symfony",
            "./vendor/bin/phpcs --standard=Symfony src/ --ignore=Kernel.php",
            "./vendor/bin/phpcs --standard=Symfony tests/  --ignore=object-mapper.php",
            "./vendor/bin/php-cs-fixer fix src/ --rules=@Symfony,@PSR1,@PSR2,@PSR12",
            "./vendor/bin/php-cs-fixer fix tests/ --rules=@Symfony,@PSR1,@PSR2,@PSR12",
            "./vendor/bin/rector process src",
            "./vendor/bin/rector process tests"
        ],
        "init-app" : [
            "./bin/console --no-interaction doctrine:migrations:migrate",
            "./bin/console --no-interaction doctrine:fixtures:load"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": "true",
            "require": "7.4.*"
        }
    }
}
