{% extends 'base.html.twig' %}

{% block title %}
    {{ 'title.category_list'|trans }}
{% endblock %}

{% block body %}

    <h1>{{ 'title.category_list'|trans }}</h1>

    {% if is_granted('ROLE_ADMIN') %}
        <p>
            <a href="{{ path('category_create') }}" class="btn btn-primary">
                {{ 'action.create'|trans }}
            </a>
        </p>
    {% endif %}

    {% if pagination is defined and pagination|length %}

        <div class="navigation text-center">
            {{ knp_pagination_render(pagination) }}
        </div>

    <table class="table table-striped">
        <thead>
        <tr>
            <th>{{ knp_pagination_sortable(pagination, 'label.id'|trans, 'category.id') }}</th>
            <th>{{ knp_pagination_sortable(pagination, 'label.name'|trans, 'category.name') }}</th>
            <th>{{ 'action.view'|trans }}</th>
            {% if is_granted('ROLE_ADMIN') %}
                <th>{{ 'action.edit'|trans }}</th>
                <th>{{ 'action.delete'|trans }}</th>
            {% endif %}
        </tr>
        </thead>

        <tbody>
        {% for category in pagination %}
            <tr>
                <td>{{ category.id }}</td>
                <td>{{ category.name }}</td>
            <td>
                <a href="{{ url('category_view', {id: category.id}) }}" title="{{ 'category.view'|trans }}">
                    {{ 'action.view'|trans }}
                </a>
            </td>
            {% if is_granted('ROLE_ADMIN') %}
                <td>
                    <a href="{{ url('category_edit', {id: category.id}) }}">
                        {{ 'action.edit'|trans }}
                    </a>
                </td>
                <td>
                    <a href="{{ url('category_delete', {id: category.id}) }}">
                        {{ 'action.delete'|trans }}
                    </a>
                </td>
            {% endif %}
            </tr>
        {% endfor %}
        </tbody>
    </table>

        <div class="navigation text-center">
            {{ knp_pagination_render(pagination) }}
        </div>

    {% else %}
    <p>
        {{ 'message.empty_list'|trans }}
    </p>
    {%  endif %}

{% endblock %}
