{% extends 'base.html.twig' %}

{% block title %}
    {{ 'title.article_list'|trans }}
{% endblock %}

{% block body %}

    <h1>{{ 'title.article_list'|trans }}</h1>

    {% if is_granted('ARTICLE_CREATE') %}
        <p>
            <a href="{{ path('article_create') }}" class="btn btn-primary">
                {{ 'action.create'|trans }}
            </a>
        </p>
    {% endif %}

    {% if pagination is defined and pagination|length %}

        <div class="navigation text-center">
            {{ knp_pagination_render(pagination) }}
        </div>

        <table class="table table-striped">
            <thead>
            <tr>
                <th>{{  knp_pagination_sortable(pagination,'label.id'|trans, 'article.id') }}</th>
                <th>{{  knp_pagination_sortable(pagination,'label.title'|trans, 'article.title') }}</th>
                <th>
                    {{ knp_pagination_sortable(
                        pagination,
                        'label.category'|trans,
                        'category.name'
                    ) }}
                </th>
                <th>{{  knp_pagination_sortable(pagination,'label.content'|trans, 'article.content') }}</th>
                <th>
                    {{  knp_pagination_sortable(pagination,'label.created_at'|trans, 'article.createdAt') }}
                </th>
                <th>{{ 'action.view'|trans }}</th>
                {% if is_granted('ARTICLE_CREATE') %}
                    <th>{{ 'action.edit'|trans }}</th>
                    <th>{{ 'action.delete'|trans }}</th>
                {% endif %}
            </tr>
            </thead>

            <tbody>
            {% for article in pagination %}
                <tr>
                    <td>{{ article.id }}</td>
                    <td>{{ article.title }}</td>
                    <td>{{ article.category.name }}</td>
                    <td>{{ article.content }}</td>
                    <td>{{ article.createdAt ? article.createdAt|date('Y-m-d H:i') : '' }}</td>
                    <td>
                        <a href="{{ path('article_view', {id: article.id}) }}">
                            {{ 'action.view'|trans }}
                        </a>
                    </td>
                    {% if is_granted('ARTICLE_EDIT', article) %}
                        <td>
                            <a href="{{ path('article_edit', {id: article.id}) }}">
                                {{ 'action.edit'|trans }}
                            </a>
                        </td>
                    {% endif %}
                    {% if is_granted('ARTICLE_DELETE', article) %}
                        <td>
                            <a href="{{ path('article_delete', {id: article.id}) }}">
                                {{ 'action.delete'|trans }}
                            </a>
                        </td>
                    {% endif %}
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="navigation text-center">
            {{ knp_pagination_render(pagination) }}
        </div>

    {% else %}
        <p>
            {{ 'message.empty_list'|trans }}
        </p>
    {% endif %}

{% endblock %}
